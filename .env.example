# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before running docker compose.
# Never commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password for the internal `db` container.
# Also used inside DATABASE_URL below — keep them in sync.
DB_PASSWORD=change_me_strong_password_here

# Full connection string used by the API server and the migrate step.
# If you're pointing at an external Postgres instance, replace the whole URL.
# Default points at the `db` service defined in docker-compose.yml.
DATABASE_URL=postgres://propbet:change_me_strong_password_here@db:5432/propbet

# Long random string used to sign sessions.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_32_plus_character_random_string

# OpenAI API key — used by the Google Sheet AI sync to read prop results.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
