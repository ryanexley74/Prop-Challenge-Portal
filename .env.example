# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before running docker compose.
# Never commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password for the internal `db` container.
# Also used inside DATABASE_URL below — keep them in sync.
DB_PASSWORD=change_me_strong_password_here

# Full connection string used by the API server and the migrate step.
# If pointing at an external Postgres instance, replace the whole URL.
# Default points at the `db` service in docker-compose.yml.
DATABASE_URL=postgres://propbet:change_me_strong_password_here@db:5432/propbet

# Long random string used to sign sessions.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_32_plus_character_random_string


# ─── AI provider for Google Sheet sync ───────────────────────────────────────
#
# The sheet sync uses an OpenAI-compatible API to read prop results from your
# Google Sheet. Three options — pick ONE and fill in the matching block below.
#
# OPTION A · OpenAI (paid — requires credits, no free tier)
#   Key:      https://platform.openai.com/api-keys
#
# OPTION B · Google Gemini (FREE tier available — recommended for most users)
#   Key:      https://aistudio.google.com/apikey   (free, no credit card)
#   Limits:   15 requests/min · 1 M tokens/day on the free plan
#
# OPTION C · Groq (FREE tier available — fastest inference)
#   Key:      https://console.groq.com             (free, no credit card)
#   Limits:   30 requests/min · 14,400 tokens/min on the free plan
#
# ─────────────────────────────────────────────────────────────────────────────

# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-proj-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# --- Option B: Google Gemini (free) ---
# OPENAI_API_KEY=AIza...          ← your Gemini API key goes here
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AI_MODEL=gemini-2.0-flash

# --- Option C: Groq (free) ---
# OPENAI_API_KEY=gsk_...          ← your Groq API key goes here
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-8b-instant

# Uncomment exactly one of the three blocks above, then fill in your key:
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_MODEL=
